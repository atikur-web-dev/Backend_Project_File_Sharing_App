// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// লগইন টাইপ (Google, GitHub, Email)
enum LoginType {
  google
  github
  email
}

// ইউজার মডেল
model User {
  id           String    @id @default(uuid())
  googleId     String    @unique
  name         String
  email        String    @unique
  picture      String?
  loginType    LoginType @default(google)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // সম্পর্ক (relations)
  sessions     Session[]
}

// সেশন মডেল (Refresh Token স্টোরের জন্য)
model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  // সম্পর্ক
  user         User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
}